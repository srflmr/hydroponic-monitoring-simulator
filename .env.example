# =============================================================================
#  Hydroponic Monitoring System Simulator — environment configuration
# =============================================================================
#  Copy this file to `.env` (which is gitignored) and replace every `change_me_*`
#  value before deploying. `docker compose up` loads `.env` automatically.
#
#  Legend:
#    [REQUIRED] — must be set; compose fails or the service misbehaves without it.
#    [OPTIONAL] — has a built-in default (shown); uncomment only to override.
#
#  SECURITY: the values in your real `.env` MUST be regenerated before any
#  non-local deployment. The placeholders here are intentionally non-functional.
# =============================================================================

# -----------------------------------------------------------------------------
#  PostgreSQL — zone config + tank state                          [REQUIRED]
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=hydroponic
# Connection string used by the services. MUST stay consistent with the three
# values above (same user / password / db / host:port).
POSTGRES_URL=postgresql://postgres:change_me_postgres@postgres:5432/hydroponic
# Per-service least-privilege role passwords (created by postgres/init/002_create_roles.sh).
# zone-config connects as zone_config_app; resource-arbitration as resource_arbitration_app.
ZONE_CONFIG_DB_PASSWORD=change_me_zone_config_db
RESOURCE_ARBITRATION_DB_PASSWORD=change_me_resource_arbitration_db

# -----------------------------------------------------------------------------
#  Redis — telemetry & request queues + tank cache                [REQUIRED]
# -----------------------------------------------------------------------------
# Per-service ACL users: each service authenticates with its own named user
# confined to the keys and commands it needs. Generate with: openssl rand -hex 20
REDIS_TELEMETRY_PASSWORD=change_me_redis_telemetry
REDIS_EVALUATOR_PASSWORD=change_me_redis_evaluator
REDIS_ARBITRATION_PASSWORD=change_me_redis_arbitration

# -----------------------------------------------------------------------------
#  InfluxDB — time-series telemetry                               [REQUIRED]
# -----------------------------------------------------------------------------
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=hydroponic-org
INFLUXDB_BUCKET=hydroponic_telemetry
INFLUXDB_RETENTION=168h
# Initial admin account created on first boot (DOCKER_INFLUXDB_INIT_*).
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=change_me_influx_admin
# All-access admin token used ONLY during InfluxDB init to provision scoped
# tokens. After first boot the init script (influxdb/init/10-scoped-tokens.sh)
# writes the generated write/read token values to
# /influx-tokens/scoped-tokens.env on the dedicated influx-tokens volume;
# telemetry-ingestion and dashboard-api mount that volume (read-only) and
# source the file at startup. This admin token is not passed to any app service.
INFLUXDB_TOKEN=change_me_influx_admin_token

# -----------------------------------------------------------------------------
#  MQTT broker (Mosquitto)                                        [REQUIRED]
# -----------------------------------------------------------------------------
# Per-service MQTT credentials. Each MQTT client authenticates with its own
# named user, confined to the topics it needs (see mosquitto/acl).
# Generate with: openssl rand -hex 20
MQTT_BROKER_URL=mqtt://mosquitto:1883
SENSOR_SIMULATOR_MQTT_PASSWORD=change_me_mqtt_sensor
TELEMETRY_MQTT_PASSWORD=change_me_mqtt_telemetry
ARBITRATION_MQTT_PASSWORD=change_me_mqtt_arbitration
ACTUATOR_MQTT_PASSWORD=change_me_mqtt_actuator
DASHBOARD_MQTT_PASSWORD=change_me_mqtt_dashboard

# -----------------------------------------------------------------------------
#  Authelia — SSO / forward-auth at the gateway                   [REQUIRED]
# -----------------------------------------------------------------------------
# Generate each as a long random string, e.g.:  openssl rand -hex 64
AUTHELIA_SESSION_SECRET=change_me_authelia_session_secret
AUTHELIA_STORAGE_ENCRYPTION_KEY=change_me_authelia_storage_key
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=change_me_authelia_jwt_secret
#
# NOTE — the operator LOGIN account is NOT configured here. It lives in
#   authelia/users_database.yml  as username `operator` with an argon2id hash
#   (demo password: operator-demo-2026). To change the login password, generate
#   a new hash and replace the `password:` field in that file:
#     docker run --rm authelia/authelia:4.38.17 \
#       authelia crypto hash generate argon2 --password 'YOUR_NEW_PASSWORD'

# -----------------------------------------------------------------------------
#  Grafana — monitoring dashboards                                [REQUIRED]
# -----------------------------------------------------------------------------
# Admin login is `admin` / this password. Anonymous Viewer is enabled so that
# Authelia-gated users get read-only access at grafana.hydroponic.localhost.
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana_admin

# -----------------------------------------------------------------------------
#  Service tuning knobs                                           [OPTIONAL]
# -----------------------------------------------------------------------------
#  All have safe defaults (shown). Compose passes them through via
#  `${VAR:-default}`, so uncommenting a line here overrides the default; leaving
#  it commented keeps the default.
#
#  resource-arbitration — score weights (PRD §13: W1=zone priority,
#  W2=criticality; they should sum to 1.0) and litres per fulfilled request.
# ARBITRATION_W1=0.4
# ARBITRATION_W2=0.6
# ALLOCATION_VOLUME_LITER=5
#
#  actuator-gateway — simulated valve actuation delay, in seconds.
# ACTUATOR_DELAY_SECONDS=1.5
#
#  sensor-simulator — telemetry publish cadence, in seconds (all zones).
# PUBLISH_INTERVAL_SECONDS=4

# -----------------------------------------------------------------------------
#  Configured directly in docker-compose.yml (NOT via .env)
# -----------------------------------------------------------------------------
#  These are per-container identity / internal service-to-service wiring and
#  are set inline in docker-compose.yml, intentionally not driven from .env:
#
#    • Per-zone sensor identity & seed values (sensor-simulator-zone-a/b/c):
#        ZONE_ID, DEVICE_ID, INIT_PH, INIT_EC, INIT_WATER_TEMP_C
#        (INIT_WATER_LEVEL_PCT defaults to 90 in code). Each zone needs its own
#        values, so they cannot be single global .env vars.
#
#    • Internal Docker-DNS service URLs (consumed server-side only):
#        ZONE_CONFIG_URL, ZONE_EVALUATOR_URL, RESOURCE_ARBITRATION_URL,
#        DASHBOARD_API_INTERNAL_URL
#
#    • Public hostname wiring (default https://hydroponic.localhost):
#        CORS_ORIGIN, ORIGIN, GF_SERVER_ROOT_URL. To serve on a different host
#        you must also update authelia/configuration.yml and
#        traefik/dynamic/dynamic.yml, so these live with the rest of that config.
