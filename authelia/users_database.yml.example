# authelia/users_database.yml.example
#
# Copy this file to `authelia/users_database.yml` (gitignored) and replace
# the password hash below with your own. Generate it with:
#
#   docker run --rm authelia/authelia:4.39.20 authelia crypto hash generate argon2 --password 'your-password-here'
#
# The command prints a line like `Digest: $argon2id$v=19$...` — copy
# everything after `Digest: ` into the `password:` field below.

users:
  operator:
    disabled: false
    displayname: "Operator"
    password: "$argon2id$v=19$m=65536,t=3,p=4$REPLACE_WITH_GENERATED_HASH"
    email: operator@hydroponic.localhost
    groups:
      - operators
