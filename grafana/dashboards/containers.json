{
  "uid": "hydro-containers",
  "title": "Containers",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "tags": [
    "monitoring"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(container_last_seen{job=\"docker-stats\"}, name)",
          "refId": "A"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1,
        "label": "Container"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 6,
      "type": "stat",
      "title": "Containers running",
      "description": "Count of containers currently reporting to docker-stats.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(container_last_seen{job=\"docker-stats\"})",
          "refId": "A",
          "editorMode": "code",
          "range": false,
          "instant": true,
          "legendFormat": "Running"
        }
      ]
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU (cores)",
      "description": "CPU cores per container (rate of cumulative CPU seconds).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(container_cpu_usage_seconds_total{job=\"docker-stats\",name=~\"$container\"}[5m])",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": false,
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU (%)",
      "description": "CPU utilisation per container as % of all cores (assumes 8 CPU cores).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(container_cpu_usage_seconds_total{job=\"docker-stats\",name=~\"$container\"}[5m]) / 8 * 100",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": false,
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory usage",
      "description": "",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "container_memory_usage_bytes{job=\"docker-stats\",name=~\"$container\"}",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": false,
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Network receive",
      "description": "",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(container_network_receive_bytes_total{job=\"docker-stats\",name=~\"$container\"}[5m])",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": false,
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Network transmit",
      "description": "",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(container_network_transmit_bytes_total{job=\"docker-stats\",name=~\"$container\"}[5m])",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": false,
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Current usage (per container)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 24,
        "h": 10
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "transformations": [
        {
          "id": "merge"
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(container_cpu_usage_seconds_total{job=\"docker-stats\",name=~\"$container\"}[5m])",
          "refId": "A",
          "editorMode": "code",
          "range": false,
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "container_memory_usage_bytes{job=\"docker-stats\",name=~\"$container\"}",
          "refId": "B",
          "editorMode": "code",
          "range": false,
          "instant": true,
          "format": "table"
        }
      ]
    }
  ]
}
